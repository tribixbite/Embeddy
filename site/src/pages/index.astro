---
import Layout from "../layouts/Layout.astro";
import FeatureCards from "../components/FeatureCards.svelte";
import AbiPicker from "../components/AbiPicker.svelte";

const techStack = [
  { name: "Kotlin 2", color: "text-purple-400 border-purple-400/20 bg-purple-400/10" },
  { name: "Jetpack Compose", color: "text-green-400 border-green-400/20 bg-green-400/10" },
  { name: "Material 3", color: "text-blue-400 border-blue-400/20 bg-blue-400/10" },
  { name: "FFmpeg-kit", color: "text-orange-400 border-orange-400/20 bg-orange-400/10" },
  { name: "avif-coder", color: "text-pink-400 border-pink-400/20 bg-pink-400/10" },
  { name: "Coil", color: "text-cyan-400 border-cyan-400/20 bg-cyan-400/10" },
  { name: "Jsoup", color: "text-yellow-400 border-yellow-400/20 bg-yellow-400/10" },
  { name: "Media3", color: "text-red-400 border-red-400/20 bg-red-400/10" },
];
---

<Layout>
  <main>
    <!-- Hero -->
    <section class="hero-gradient relative overflow-hidden">
      <!-- Subtle grid pattern overlay -->
      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='40' height='40' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40' fill='none' stroke='white' stroke-width='0.5'/%3E%3C/svg%3E&quot;);"
      >
      </div>

      <div class="relative mx-auto max-w-5xl px-4 pb-20 pt-24 sm:px-6 lg:pt-32">
        <!-- Badge -->
        <div class="mb-8 flex justify-center">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300"
          >
            <span class="h-2 w-2 rounded-full bg-brand-400 animate-pulse"></span>
            v0.1.12 &mdash; Latest Release
          </span>
        </div>

        <!-- Title -->
        <h1
          class="mx-auto max-w-3xl text-center text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl"
        >
          Swiss-army knife for
          <span
            class="bg-gradient-to-r from-brand-400 to-accent bg-clip-text text-transparent"
          >
            embeddable media
          </span>
          on Android
        </h1>

        <!-- Subtitle -->
        <p
          class="mx-auto mt-6 max-w-2xl text-center text-lg text-white/60 leading-relaxed"
        >
          Animated WebP converter, image compressor, OG metadata inspector,
          and anonymous file uploader. On Android and in your browser.
        </p>

        <!-- CTA -->
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="https://github.com/tribixbite/Embeddy/releases/latest"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-brand-500 px-8 py-3.5 font-semibold text-white transition-all hover:bg-brand-400 hover:shadow-lg hover:shadow-brand-500/25"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download APK
          </a>
          <a
            href="https://github.com/tribixbite/Embeddy"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/15 bg-white/5 px-8 py-3.5 font-semibold text-white transition-all hover:bg-white/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            View Source
          </a>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          Four tabs. Zero friction.
        </h2>
        <p class="mt-3 text-white/50">
          Everything you need for embeddable media, in one compact app.
        </p>
      </div>

      <FeatureCards client:visible />
    </section>

    <!-- Web Tools CTA -->
    <section class="border-y border-white/5 bg-white/[0.02]">
      <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 text-center">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">
          Try in your browser
        </h2>
        <p class="mt-3 mb-8 text-white/50">
          No download needed. Squoosh, Inspect, and Upload work right here.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/tools/squoosh"
            class="inline-flex items-center gap-2 rounded-xl border border-brand-500/30 bg-brand-500/10 px-6 py-3 text-sm font-semibold text-brand-300 transition-all hover:bg-brand-500/20"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
            Squoosh
          </a>
          <a
            href="/tools/inspect"
            class="inline-flex items-center gap-2 rounded-xl border border-brand-500/30 bg-brand-500/10 px-6 py-3 text-sm font-semibold text-brand-300 transition-all hover:bg-brand-500/20"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            Inspect
          </a>
          <a
            href="/tools/upload"
            class="inline-flex items-center gap-2 rounded-xl border border-brand-500/30 bg-brand-500/10 px-6 py-3 text-sm font-semibold text-brand-300 transition-all hover:bg-brand-500/20"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
            </svg>
            Upload
          </a>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="border-y border-white/5 bg-white/[0.01]">
      <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
        <h2 class="mb-8 text-center text-sm font-semibold tracking-widest text-white/40 uppercase">
          Built with
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {
            techStack.map((tech) => (
              <span
                class={`rounded-lg border px-4 py-2 text-sm font-medium ${tech.color}`}
              >
                {tech.name}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Download -->
    <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
      <div class="mb-10 text-center">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">
          Get Embeddy
        </h2>
        <p class="mt-3 text-white/50">
          Choose the right APK for your device architecture.
        </p>
      </div>

      <div class="mx-auto max-w-2xl">
        <AbiPicker client:visible />
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-white/5">
      <div class="mx-auto flex max-w-5xl flex-col items-center gap-4 px-4 py-10 sm:flex-row sm:justify-between sm:px-6">
        <div class="flex items-center gap-3 text-sm text-white/40">
          <span class="font-semibold text-white/60">Embeddy</span>
          <span>&middot;</span>
          <a
            href="https://www.gnu.org/licenses/gpl-3.0.html"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white/60 transition-colors"
          >
            GPL-3.0
          </a>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/tribixbite/Embeddy"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/40 transition-colors hover:text-white/70"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
          </a>
          <span class="text-xs text-white/30">
            by <a href="https://github.com/tribixbite" target="_blank" rel="noopener noreferrer" class="hover:text-white/50 transition-colors">tribixbite</a>
          </span>
        </div>
      </div>
    </footer>
  </main>
</Layout>
